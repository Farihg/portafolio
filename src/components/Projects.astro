---
// Importar imágenes directamente
import petlifeImage from '../data/petlife.png';
import viajecitoImage from '../data/favicon.png'; // Asumo que es la imagen para Tu Viajecito

const projects = [
    {
        title: "Tu Viajecito",
        tags: ["Web App", "Full Stack", "Astro"],
        description: "Aplicación web completa para organizar viajes mediante listas y checklists personalizadas. Permite crear listas desde cero o usar plantillas, agregar e ítems con persistencia.",
        details: "Desarrollé toda la aplicación: frontend con React/Next.js, backend con API, autenticación con NextAuth y base de datos con PostgreSQL. Deployment en Render.",
        image: viajecitoImage,
        demo: "#",
        repo: "#"
    },
    {
        title: "Tu PetLife",
        tags: ["Backend", "API", "Seguridad"],
        description: "Sistema backend para aplicación de cuidado de mascotas, enfocándome en la integración entre backend y frontend, lógica del servidor y seguridad con JWT.",
        details: "Trabajé principalmente en conexiones con APIs externas, desarrollo de la lógica backend, implementación de autenticación JWT y comunicación eficiente frontend-backend.",
        image: petlifeImage,
        demo: "#",
        repo: "#"
    }
];
---

<section id="projects" class="projects">
    <div class="container">
        <h2>Proyectos Destacados</h2>
        <p class="projects-intro">Aquí algunos de mis proyectos más relevantes, donde aplico mis conocimientos técnicos para resolver problemas reales.</p>
        
        <div class="projects-grid">
            {projects.map((project) => (
                <article class="project-card">
                    <div class="project-visual">
                        <!-- Contenedor de imagen optimizado -->
                        <div class="image-wrapper">
                            <img src={project.image.src} alt={project.title} class="project-image" loading="lazy" />
                        </div>
                        <div class="floating-particles">
                            <div class="particle"></div>
                            <div class="particle"></div>
                            <div class="particle"></div>
                        </div>
                    </div>
                    
                    <div class="project-header">
                        <h3>{project.title}</h3>
                        <div class="project-tags">
                            {project.tags.map(tag => <span class="tag">{tag}</span>)}
                        </div>
                    </div>

                    <div class="project-content">
                        <p class="description">{project.description}</p>
                        <p class="details">{project.details}</p>
                    </div>

                    <div class="project-links">
                        <a href={project.demo} class="project-link primary">Ver Demo</a>
                        <a href={project.repo} class="project-link secondary">Código Fuente</a>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .projects { 
        padding: 5rem 2rem; 
        background: linear-gradient(135deg, #f8fffe 0%, #e8f5f0 50%, #f0fdf4 100%); 
        position: relative; 
        overflow: hidden; 
    }
    
    .container { max-width: 1200px; margin: 0 auto; position: relative; z-index: 2; }
    
    .projects h2 { 
        text-align: center; 
        font-size: 2.5rem; 
        margin-bottom: 1rem; 
        font-weight: 700; 
        background: linear-gradient(45deg, #0f5132, #16a34a); 
        -webkit-background-clip: text; 
        -webkit-text-fill-color: transparent; 
    }
    
    .projects-intro { text-align: center; font-size: 1.2rem; margin-bottom: 3rem; color: #374151; max-width: 700px; margin-left: auto; margin-right: auto; }
    
    .projects-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); 
        gap: 2.5rem; 
    }
    
    .project-card { 
        background: rgba(255, 255, 255, 0.95); 
        border: 1px solid rgba(34, 197, 94, 0.2); 
        border-radius: 24px; 
        padding: 1.5rem; 
        display: flex;
        flex-direction: column;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
    }
    
    .project-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(15, 81, 50, 0.1); }

    /* Ajuste para que las fotos se vean perfectas */
    .image-wrapper {
        width: 100%;
        aspect-ratio: 16 / 9; /* Mantiene una proporción constante */
        overflow: hidden;
        border-radius: 16px;
        background: #eee;
        margin-bottom: 1.5rem;
    }

    .project-image { 
        width: 100%; 
        height: 100%; 
        object-fit: cover; /* Recorta la imagen para llenar el espacio sin deformarse */
        object-position: center;
        transition: transform 0.5s ease;
    }

    .project-card:hover .project-image {
        transform: scale(1.05);
    }

    .project-header h3 { margin: 0 0 0.75rem 0; font-size: 1.6rem; color: #0f5132; }
    
    .project-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    
    .tag { 
        background: rgba(34, 197, 94, 0.1); 
        color: #16a34a; 
        padding: 0.2rem 0.8rem; 
        border-radius: 12px; 
        font-size: 0.75rem; 
        font-weight: 600; 
        border: 1px solid rgba(34, 197, 94, 0.2);
    }
    
    .project-content { flex-grow: 1; }
    .project-content p { font-size: 0.95rem; line-height: 1.5; color: #4b5563; }
    .project-content .description { font-weight: 500; margin-bottom: 0.5rem; }
    .project-content .details { font-size: 0.85rem; opacity: 0.8; }

    .project-links { display: flex; gap: 1rem; margin-top: 1.5rem; }
    
    .project-link { 
        flex: 1;
        text-align: center;
        padding: 0.8rem; 
        border-radius: 14px; 
        text-decoration: none; 
        font-weight: 600; 
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }
    
    .project-link.primary { background: #16a34a; color: white; border: 1px solid #16a34a; }
    .project-link.primary:hover { background: #0f5132; }
    
    .project-link.secondary { background: white; color: #16a34a; border: 1px solid #16a34a; }
    .project-link.secondary:hover { background: rgba(22, 163, 74, 0.05); }

    /* Partículas sutiles */
    .floating-particles { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
    .particle { position: absolute; width: 6px; height: 6px; background: #4ade80; border-radius: 50%; opacity: 0.3; }
    
    @media (max-width: 768px) { 
        .projects-grid { grid-template-columns: 1fr; } 
    }

    .image-wrapper {
        width: 100%;
        height: 250px; /* Altura fija para todas las tarjetas */
        overflow: hidden;
        border-radius: 16px;
        /* IMPORTANTE: Poné acá el color de fondo de tus imágenes 
           (ej: blanco #fff, o el gris claro de fondo #e8f5f0) */
        background-color: #ffffff; 
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(0,0,0,0.05); /* Un borde sutil */
    }

    /* La imagen real */
    .project-image { 
        /* IMPORTANTE: 'contain' hace que la foto quepa ENTERA sin cortes */
        object-fit: contain; 
        width: 100%;
        height: 100%;
        /* Le damos un aire (padding) para que no toque los bordes */
        padding: 1.5rem; 
        transition: transform 0.5s ease;
    }

    /* Efecto sutil al pasar el mouse */
    .project-card:hover .project-image {
        transform: scale(1.08);
    }
</style>