---
// Tech Stack section component
---

<section id="tech-stack" class="tech-stack">
	<div class="tech-bg-particles">
		<div class="particle-tech"></div>
		<div class="particle-tech"></div>
		<div class="particle-tech"></div>
		<div class="particle-tech"></div>
		<div class="particle-tech"></div>
		<div class="particle-tech"></div>
		<div class="particle-tech"></div>
		<div class="particle-tech"></div>
	</div>
	<div class="container">
		<h2 class="tech-title">Stack Tecnológico</h2>
		<p class="stack-intro">Trabajo con un conjunto de tecnologías modernas y robustas para crear soluciones completas y escalables.</p>
		<div class="tech-grid">
			<div class="tech-category">
				<h3 class="category-title">Lenguajes de Programación</h3>
				<div class="tech-items">
					<div class="tech-item java">
						<div class="tech-icon-wrapper">
							<span class="tech-icon">☕</span>
						</div>
						<div class="tech-info">
							<span class="tech-name">Java</span>
							<div class="tech-level-bar">
								<div class="level-fill advanced"></div>
							</div>
							<span class="tech-level-text">Avanzado</span>
						</div>
					</div>
					<div class="tech-item javascript">
						<div class="tech-icon-wrapper">
							<span class="tech-icon">🟨</span>
						</div>
						<div class="tech-info">
							<span class="tech-name">JavaScript</span>
							<div class="tech-level-bar">
								<div class="level-fill advanced"></div>
							</div>
							<span class="tech-level-text">Avanzado</span>
						</div>
					</div>
					<div class="tech-item typescript">
						<div class="tech-icon-wrapper">
							<span class="tech-icon">🔷</span>
						</div>
						<div class="tech-info">
							<span class="tech-name">TypeScript</span>
							<div class="tech-level-bar">
								<div class="level-fill intermediate"></div>
							</div>
							<span class="tech-level-text">Intermedio</span>
						</div>
					</div>
					<div class="tech-item python">
						<div class="tech-icon-wrapper">
							<span class="tech-icon">🐍</span>
						</div>
						<div class="tech-info">
							<span class="tech-name">Python</span>
							<div class="tech-level-bar">
								<div class="level-fill intermediate"></div>
							</div>
							<span class="tech-level-text">Intermedio</span>
						</div>
					</div>
				</div>
			</div>
			<div class="tech-category">
				<h3 class="category-title">Frameworks & Librerías</h3>
				<div class="tech-items">
					<div class="tech-item react">
						<div class="tech-icon-wrapper">
							<span class="tech-icon">⚛️</span>
						</div>
						<div class="tech-info">
							<span class="tech-name">React</span>
							<div class="tech-level-bar">
								<div class="level-fill advanced"></div>
							</div>
							<span class="tech-level-text">Avanzado</span>
						</div>
					</div>
					<div class="tech-item nextjs">
						<div class="tech-icon-wrapper">
							<span class="tech-icon">▲</span>
						</div>
						<div class="tech-info">
							<span class="tech-name">Next.js</span>
							<div class="tech-level-bar">
								<div class="level-fill intermediate"></div>
							</div>
							<span class="tech-level-text">Intermedio</span>
						</div>
					</div>
					<div class="tech-item nodejs">
						<div class="tech-icon-wrapper">
							<span class="tech-icon">🟢</span>
						</div>
						<div class="tech-info">
							<span class="tech-name">Node.js</span>
							<div class="tech-level-bar">
								<div class="level-fill advanced"></div>
							</div>
							<span class="tech-level-text">Avanzado</span>
						</div>
					</div>
				</div>
			</div>
			<div class="tech-category">
				<h3 class="category-title">Web Básico</h3>
				<div class="tech-items">
					<div class="tech-item html">
						<div class="tech-icon-wrapper">
							<span class="tech-icon">🏗️</span>
						</div>
						<div class="tech-info">
							<span class="tech-name">HTML5</span>
							<div class="tech-level-bar">
								<div class="level-fill advanced"></div>
							</div>
							<span class="tech-level-text">Avanzado</span>
						</div>
					</div>
					<div class="tech-item css">
						<div class="tech-icon-wrapper">
							<span class="tech-icon">🎨</span>
						</div>
						<div class="tech-info">
							<span class="tech-name">CSS3</span>
							<div class="tech-level-bar">
								<div class="level-fill advanced"></div>
							</div>
							<span class="tech-level-text">Avanzado</span>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="backend-note">
			<div class="note-content">
				<span class="note-icon">🔧</span>
				<p>Además, tengo conocimientos sólidos en desarrollo backend y nociones de arquitectura de microservicios, lo que me permite diseñar soluciones completas y escalables.</p>
			</div>
		</div>
	</div>
</section>

<style>
	.tech-stack {
		padding: 5rem 2rem;
		background:
			linear-gradient(135deg, #0f5132 0%, #14532d 50%, #166534 100%),
			radial-gradient(circle at 25% 75%, rgba(74, 222, 128, 0.1) 0%, transparent 50%),
			radial-gradient(circle at 75% 25%, rgba(34, 197, 94, 0.1) 0%, transparent 50%);
		color: white;
		position: relative;
		overflow: hidden;
	}
	.tech-stack::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="circuit" width="15" height="15" patternUnits="userSpaceOnUse"><path d="M0 7.5 L7.5 7.5 L7.5 0" stroke="%234ade80" stroke-width="0.3" opacity="0.08" fill="none"/><circle cx="10" cy="10" r="0.8" fill="%234ade80" opacity="0.06"/><rect x="12" y="2" width="1" height="1" fill="%234ade80" opacity="0.04"/></pattern></defs><rect width="100" height="100" fill="url(%23circuit)"/></svg>');
		pointer-events: none;
		animation: circuitShift 25s ease-in-out infinite;
	}
	@keyframes circuitShift {
		0%, 100% { transform: translate(0, 0) rotate(0deg); }
		50% { transform: translate(-15px, -10px) rotate(0.5deg); }
	}
	.tech-bg-particles {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}
	.particle-tech {
		position: absolute;
		width: 2px;
		height: 2px;
		background: linear-gradient(45deg, #4ade80, #22c55e);
		border-radius: 50%;
		opacity: 0.6;
		animation: particleCircuit 12s ease-in-out infinite;
	}
	.particle-tech:nth-child(1) { top: 20%; left: 15%; animation-delay: 0s; }
	.particle-tech:nth-child(2) { top: 35%; right: 25%; animation-delay: 3s; }
	.particle-tech:nth-child(3) { bottom: 40%; left: 30%; animation-delay: 6s; }
	.particle-tech:nth-child(4) { top: 60%; right: 20%; animation-delay: 9s; }
	.particle-tech:nth-child(5) { bottom: 25%; right: 35%; animation-delay: 12s; }
	.particle-tech:nth-child(6) { top: 45%; left: 60%; animation-delay: 15s; }
	.particle-tech:nth-child(7) { bottom: 55%; left: 70%; animation-delay: 18s; }
	.particle-tech:nth-child(8) { top: 75%; right: 45%; animation-delay: 21s; }
	@keyframes particleCircuit {
		0%, 100% {
			transform: translateY(0px) translateX(0px) scale(1);
			opacity: 0.6;
		}
		50% {
			transform: translateY(-30px) translateX(25px) scale(1.5);
			opacity: 1;
		}
	}
	.container {
		max-width: 1200px;
		margin: 0 auto;
		position: relative;
		z-index: 2;
	}
	.tech-stack h2 {
		text-align: center;
		font-size: 2.5rem;
		margin-bottom: 1rem;
		color: #a7f3d0;
		font-weight: 700;
		position: relative;
		animation: titleGlow 2s ease-out;
	}
	.tech-title::after {
		content: '';
		position: absolute;
		bottom: -8px;
		left: 50%;
		transform: translateX(-50%);
		width: 100px;
		height: 3px;
		background: linear-gradient(90deg, #4ade80, #22c55e);
		border-radius: 2px;
		animation: lineGlow 1s ease-out 0.5s both;
	}
	@keyframes titleGlow {
		from {
			opacity: 0;
			transform: translateY(-20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@keyframes lineGlow {
		from { width: 0; }
		to { width: 100px; }
	}
	.stack-intro {
		text-align: center;
		font-size: 1.2rem;
		margin-bottom: 3rem;
		color: #d1fae5;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
		animation: fadeInIntro 1s ease-out 0.3s both;
	}
	@keyframes fadeInIntro {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	.tech-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		margin-bottom: 3rem;
		animation: gridSlideIn 1s ease-out 0.6s both;
	}
	@keyframes gridSlideIn {
		from {
			opacity: 0;
			transform: translateY(40px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	.tech-category {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(74, 222, 128, 0.1);
		border-radius: 20px;
		padding: 2rem;
		backdrop-filter: blur(15px);
		transition: all 0.4s ease;
		animation: categoryFloat 0.8s ease-out both;
	}
	.tech-category:nth-child(1) { animation-delay: 0.8s; }
	.tech-category:nth-child(2) { animation-delay: 1s; }
	.tech-category:nth-child(3) { animation-delay: 1.2s; }
	.tech-category:hover {
		transform: translateY(-5px);
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(74, 222, 128, 0.3);
		box-shadow: 0 15px 35px rgba(34, 197, 94, 0.2);
	}
	@keyframes categoryFloat {
		from {
			opacity: 0;
			transform: translateY(30px) scale(0.95);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}
	.category-title {
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
		color: #4ade80;
		border-bottom: 2px solid #4ade80;
		padding-bottom: 0.5rem;
		position: relative;
	}
	.category-title::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, #22c55e, #16a34a);
		transition: width 0.4s ease;
	}
	.tech-category:hover .category-title::after {
		width: 100%;
	}
	.tech-items {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.tech-item {
		display: flex;
		align-items: center;
		padding: 1.25rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(74, 222, 128, 0.2);
		border-radius: 15px;
		backdrop-filter: blur(10px);
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		cursor: pointer;
		position: relative;
		overflow: hidden;
		animation: itemSlideIn 0.6s ease-out both;
	}
	.tech-item:nth-child(1) { animation-delay: 1s; }
	.tech-item:nth-child(2) { animation-delay: 1.1s; }
	.tech-item:nth-child(3) { animation-delay: 1.2s; }
	.tech-item:nth-child(4) { animation-delay: 1.3s; }
	.tech-item:nth-child(5) { animation-delay: 1.4s; }
	.tech-item:nth-child(6) { animation-delay: 1.5s; }
	.tech-item:nth-child(7) { animation-delay: 1.6s; }
	.tech-item:nth-child(8) { animation-delay: 1.7s; }
	.tech-item::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(74, 222, 128, 0.1), transparent);
		transition: left 0.6s ease;
	}
	.tech-item:hover::before {
		left: 100%;
	}
	.tech-item:hover {
		transform: translateX(10px) scale(1.02);
		background: rgba(255, 255, 255, 0.1);
		border-color: #4ade80;
		box-shadow: 0 10px 30px rgba(34, 197, 94, 0.3);
	}
	@keyframes itemSlideIn {
		from {
			opacity: 0;
			transform: translateX(-30px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}
	.tech-icon-wrapper {
		width: 50px;
		height: 50px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(74, 222, 128, 0.1);
		border: 2px solid rgba(74, 222, 128, 0.3);
		border-radius: 12px;
		margin-right: 1rem;
		transition: all 0.3s ease;
		position: relative;
	}
	.tech-item:hover .tech-icon-wrapper {
		background: rgba(74, 222, 128, 0.2);
		border-color: #4ade80;
		transform: scale(1.1) rotate(5deg);
		box-shadow: 0 0 20px rgba(74, 222, 128, 0.4);
	}
	.tech-icon {
		font-size: 1.5rem;
		transition: transform 0.3s ease;
	}
	.tech-item:hover .tech-icon {
		transform: scale(1.2);
	}
	.tech-info {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.tech-name {
		font-weight: 600;
		font-size: 1.1rem;
		color: #e2e8f0;
	}
	.tech-level-bar {
		width: 100%;
		height: 6px;
		background: rgba(255, 255, 255, 0.1);
		border-radius: 3px;
		overflow: hidden;
		position: relative;
	}
	.level-fill {
		height: 100%;
		border-radius: 3px;
		position: relative;
		animation: levelGrow 1.5s ease-out both;
	}
	.level-fill.advanced {
		background: linear-gradient(90deg, #16a34a, #22c55e, #4ade80);
		width: 90%;
		animation-delay: 1.8s;
	}
	.level-fill.intermediate {
		background: linear-gradient(90deg, #ca8a04, #eab308, #facc15);
		width: 70%;
		animation-delay: 1.8s;
	}
	@keyframes levelGrow {
		from { width: 0; }
		to { width: var(--target-width, 90%); }
	}
	.tech-level-text {
		font-size: 0.85rem;
		font-weight: 500;
		align-self: flex-end;
		padding: 0.2rem 0.6rem;
		border-radius: 12px;
		background: rgba(34, 197, 94, 0.2);
		color: #a7f3d0;
		border: 1px solid rgba(74, 222, 128, 0.3);
	}
	.backend-note {
		text-align: center;
		animation: noteFadeIn 1s ease-out 2s both;
	}
	@keyframes noteFadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	.note-content {
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(74, 222, 128, 0.2);
		border-radius: 20px;
		padding: 1.5rem 2rem;
		backdrop-filter: blur(10px);
		max-width: 700px;
		margin: 0 auto;
		transition: all 0.3s ease;
	}
	.note-content:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(74, 222, 128, 0.4);
		transform: translateY(-2px);
	}
	.note-icon {
		font-size: 1.5rem;
		color: #4ade80;
	}
	.backend-note p {
		font-style: italic;
		color: #d1fae5;
		font-size: 1rem;
		margin: 0;
		line-height: 1.5;
	}
	@media (max-width: 768px) {
		.tech-stack {
			padding: 3rem 1rem;
		}
		.tech-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
		.tech-stack h2 {
			font-size: 2rem;
		}
		.stack-intro {
			font-size: 1rem;
		}
		.tech-category {
			padding: 1.5rem;
		}
		.tech-item {
			padding: 1rem;
			flex-direction: column;
			text-align: center;
			gap: 0.75rem;
		}
		.tech-item:hover {
			transform: translateY(-3px) scale(1.01);
		}
		.tech-icon-wrapper {
			margin-right: 0;
			margin-bottom: 0.5rem;
		}
		.tech-info {
			align-items: center;
		}
		.tech-level-bar {
			width: 120px;
		}
		.note-content {
			flex-direction: column;
			text-align: center;
			padding: 1rem 1.5rem;
		}
		.note-icon {
			margin-bottom: 0.5rem;
		}
		.backend-note p {
			font-size: 0.9rem;
		}
	}
</style>
<!-- TechStack.astro -->