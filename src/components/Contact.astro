---
// Contact section component
---

<section id="contact" class="contact">
	<div class="contact-bg-particles">
		<div class="particle-contact"></div>
		<div class="particle-contact"></div>
		<div class="particle-contact"></div>
		<div class="particle-contact"></div>
		<div class="particle-contact"></div>
		<div class="particle-contact"></div>
		<div class="particle-contact"></div>
	</div>
	<div class="container">
		<h2 class="contact-title">Contacto</h2>
		<div class="contact-content">
			<div class="contact-message">
				<h3 class="message-title">¿Hablamos?</h3>
				<div class="message-content">
					<p>
						Estoy interesado en oportunidades de trabajo donde pueda aportar mis conocimientos
						en desarrollo full stack. Si buscas a alguien organizado, proactivo y con
						experiencia en tecnologías modernas, me gustaría conversar sobre cómo podemos
						colaborar.
					</p>
					<p>
						Puedes contactarme para discutir proyectos, oportunidades laborales o simplemente
						para intercambiar ideas sobre desarrollo de software.
					</p>
				</div>
				<div class="contact-cta">
					<a href="mailto:agustin@ejemplo.com" class="cta-button primary">
						<span class="button-text">Envíame un Email</span>
						<div class="button-shine"></div>
					</a>
					<a href="https://linkedin.com/in/agustin" class="cta-button secondary" target="_blank">
						<span class="button-text">Conectemos en LinkedIn</span>
					</a>
				</div>
			</div>

			<div class="contact-form-container">
				<h3 class="form-title">¿Hablamos?</h3>
				<form class="contact-form" novalidate>
					<div class="form-group">
						<label for="name">Nombre</label>
						<input
							type="text"
							id="name"
							name="name"
							placeholder="Tu nombre completo"
							required
						/>
					</div>

					<div class="form-group">
						<label for="email">Email</label>
						<input
							type="email"
							id="email"
							name="email"
							placeholder="tu@email.com"
							required
						/>
					</div>

					<div class="form-group">
						<label for="subject">Asunto</label>
						<input
							type="text"
							id="subject"
							name="subject"
							placeholder="¿Sobre qué quieres hablar?"
							required
						/>
					</div>

					<div class="form-group">
						<label for="message">Mensaje</label>
						<textarea
							id="message"
							name="message"
							rows="5"
							placeholder="Cuéntame sobre tu proyecto o idea..."
							required
						></textarea>
					</div>

					<button type="submit" class="submit-button">
						<span class="submit-text">Enviar Mensaje</span>
						<div class="submit-shine"></div>
					</button>
				</form>
			</div>
		</div>
	</div>
</section>

<style>
	.contact {
		padding: 5rem 2rem;
		background:
			linear-gradient(135deg, #0f5132 0%, #14532d 50%, #166534 100%),
			radial-gradient(circle at 30% 20%, rgba(74, 222, 128, 0.1) 0%, transparent 50%),
			radial-gradient(circle at 70% 80%, rgba(34, 197, 94, 0.1) 0%, transparent 50%);
		color: white;
		position: relative;
		overflow: hidden;
	}

	.contact::before {
		content: '';
		position: absolute;
		inset: 0;
		background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="connect" width="30" height="30" patternUnits="userSpaceOnUse"><circle cx="15" cy="15" r="1.5" fill="%234ade80" opacity="0.08"/><line x1="15" y1="15" x2="30" y2="15" stroke="%234ade80" stroke-width="0.8" opacity="0.06"/><line x1="15" y1="15" x2="15" y2="30" stroke="%234ade80" stroke-width="0.8" opacity="0.06"/><circle cx="15" cy="15" r="8" fill="none" stroke="%234ade80" stroke-width="0.3" opacity="0.04"/></pattern></defs><rect width="100" height="100" fill="url(%23connect)"/></svg>');
		pointer-events: none;
		animation: connectPulse 20s ease-in-out infinite;
	}

	@keyframes connectPulse {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg);
		}
		50% {
			transform: translate(-10px, -5px) rotate(0.5deg);
		}
	}

	.contact-bg-particles {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.particle-contact {
		position: absolute;
		width: 3px;
		height: 3px;
		background: linear-gradient(45deg, #4ade80, #22c55e);
		border-radius: 50%;
		opacity: 0.5;
		animation: particleConnect 14s ease-in-out infinite;
	}

	.particle-contact:nth-child(1) {
		top: 15%;
		left: 10%;
		animation-delay: 0s;
	}

	.particle-contact:nth-child(2) {
		top: 30%;
		right: 20%;
		animation-delay: 2s;
	}

	.particle-contact:nth-child(3) {
		bottom: 40%;
		left: 25%;
		animation-delay: 4s;
	}

	.particle-contact:nth-child(4) {
		top: 65%;
		right: 15%;
		animation-delay: 6s;
	}

	.particle-contact:nth-child(5) {
		bottom: 20%;
		right: 30%;
		animation-delay: 8s;
	}

	.particle-contact:nth-child(6) {
		top: 50%;
		left: 65%;
		animation-delay: 10s;
	}

	.particle-contact:nth-child(7) {
		bottom: 60%;
		left: 75%;
		animation-delay: 12s;
	}

	@keyframes particleConnect {
		0%,
		100% {
			transform: translateY(0px) translateX(0px) scale(1);
			opacity: 0.5;
		}
		50% {
			transform: translateY(-35px) translateX(20px) scale(1.4);
			opacity: 0.9;
		}
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		position: relative;
		z-index: 2;
	}

	.contact h2 {
		text-align: center;
		font-size: 2.5rem;
		margin-bottom: 3rem;
		color: #a7f3d0;
		font-weight: 700;
		position: relative;
		animation: titleRise 1s ease-out;
	}

	.contact-title::after {
		content: '';
		position: absolute;
		bottom: -10px;
		left: 50%;
		transform: translateX(-50%);
		width: 120px;
		height: 4px;
		background: linear-gradient(90deg, #4ade80, #22c55e);
		border-radius: 2px;
		animation: lineSweep 1s ease-out 0.5s both;
	}

	@keyframes titleRise {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes lineSweep {
		from {
			width: 0;
		}
		to {
			width: 120px;
		}
	}

	.contact-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		animation: contentSlideUp 1s ease-out 0.3s both;
	}

	@keyframes contentSlideUp {
		from {
			opacity: 0;
			transform: translateY(50px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.contact-message {
		animation: messageSlideLeft 1s ease-out 0.6s both;
	}

	@keyframes messageSlideLeft {
		from {
			opacity: 0;
			transform: translateX(-40px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.message-title {
		font-size: 1.8rem;
		margin-bottom: 1.5rem;
		color: #d1fae5;
		font-weight: 600;
		position: relative;
	}

	.message-title::before {
		content: '💬';
		position: absolute;
		left: -40px;
		top: 0;
		font-size: 1.5rem;
		opacity: 0.7;
	}

	.message-content {
		margin-bottom: 2rem;
	}

	.contact-message p {
		font-size: 1.1rem;
		line-height: 1.7;
		margin-bottom: 1.5rem;
		color: #e2e8f0;
		padding: 1rem;
		background: rgba(255, 255, 255, 0.03);
		border-left: 3px solid #4ade80;
		border-radius: 0 10px 10px 0;
		transition: all 0.3s ease;
	}

	.contact-message p:hover {
		background: rgba(255, 255, 255, 0.06);
		transform: translateX(5px);
	}

	.contact-cta {
		display: flex;
		gap: 1rem;
		margin-top: 2rem;
		flex-wrap: wrap;
		animation: ctaBounceIn 1s ease-out 1s both;
	}

	@keyframes ctaBounceIn {
		from {
			opacity: 0;
			transform: translateY(20px) scale(0.9);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	.cta-button {
		display: inline-block;
		padding: 1rem 2rem;
		text-decoration: none;
		border-radius: 50px;
		font-weight: 600;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		font-size: 1.1rem;
		text-align: center;
		min-width: 180px;
		position: relative;
		overflow: hidden;
		border: 2px solid transparent;
	}

	.cta-button span {
		position: relative;
		z-index: 2;
	}

	.button-shine {
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
		transition: left 0.7s ease;
	}

	.cta-button:hover .button-shine {
		left: 100%;
	}

	.cta-button.primary {
		background: linear-gradient(45deg, #16a34a, #22c55e);
		color: white;
		box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);
	}

	.cta-button.primary:hover {
		transform: translateY(-3px) scale(1.05);
		box-shadow: 0 8px 25px rgba(34, 197, 94, 0.5);
	}

	.cta-button.secondary {
		background: rgba(255, 255, 255, 0.1);
		color: #a7f3d0;
		border-color: #4ade80;
		backdrop-filter: blur(15px);
	}

	.cta-button.secondary:hover {
		background: rgba(255, 255, 255, 0.2);
		color: white;
		transform: translateY(-2px);
		border-color: #22c55e;
	}

	.contact-form-container {
		animation: formSlideRight 1s ease-out 0.8s both;
	}

	@keyframes formSlideRight {
		from {
			opacity: 0;
			transform: translateX(40px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.form-title {
		font-size: 1.5rem;
		margin-bottom: 2rem;
		color: #d1fae5;
		font-weight: 600;
		position: relative;
	}

	.form-title::before {
		content: '📝';
		position: absolute;
		left: -35px;
		top: 0;
		font-size: 1.3rem;
		opacity: 0.7;
	}

	.contact-form {
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(74, 222, 128, 0.3);
		border-radius: 20px;
		padding: 2.5rem;
		backdrop-filter: blur(20px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
	}

	.contact-form::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(74, 222, 128, 0.1), transparent);
		transition: left 0.6s ease;
	}

	.contact-form:hover::before {
		left: 100%;
	}

	.contact-form:hover {
		background: rgba(255, 255, 255, 0.12);
		border-color: rgba(74, 222, 128, 0.5);
		transform: translateY(-2px);
		box-shadow: 0 12px 40px rgba(34, 197, 94, 0.2);
	}

	.form-group {
		margin-bottom: 1.5rem;
		position: relative;
	}

	.form-group label {
		display: block;
		margin-bottom: 0.5rem;
		color: #a7f3d0;
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.form-group input,
	.form-group textarea {
		width: 100%;
		padding: 1rem;
		border: 2px solid rgba(74, 222, 128, 0.3);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.1);
		color: white;
		font-size: 1rem;
		transition: all 0.3s ease;
		font-family: inherit;
	}

	.form-group input::placeholder,
	.form-group textarea::placeholder {
		color: #9ca3af;
		transition: color 0.3s ease;
	}

	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: #4ade80;
		background: rgba(255, 255, 255, 0.15);
		box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.2);
		transform: translateY(-1px);
	}

	.form-group input:focus::placeholder,
	.form-group textarea:focus::placeholder {
		color: #6b7280;
	}

	.form-group.has-error label {
		color: #fecaca;
	}

	.form-group.has-error input,
	.form-group.has-error textarea {
		border-color: rgba(248, 113, 113, 0.95);
		background: rgba(127, 29, 29, 0.18);
		box-shadow:
			0 0 0 3px rgba(239, 68, 68, 0.15),
			0 8px 22px rgba(239, 68, 68, 0.08);
	}

	.form-group.has-error input::placeholder,
	.form-group.has-error textarea::placeholder {
		color: #fca5a5;
	}

	.field-error {
		margin-top: 0.55rem;
		font-size: 0.88rem;
		line-height: 1.35;
		color: #fecaca;
		display: flex;
		align-items: center;
		gap: 0.45rem;
		animation: fieldErrorIn 0.22s ease;
	}

	.field-error::before {
		content: '•';
		font-size: 1rem;
		color: #f87171;
	}

	.form-group.shake {
		animation: fieldShake 0.34s ease;
	}

	@keyframes fieldShake {
		0%,
		100% {
			transform: translateX(0);
		}
		20% {
			transform: translateX(-4px);
		}
		40% {
			transform: translateX(4px);
		}
		60% {
			transform: translateX(-3px);
		}
		80% {
			transform: translateX(3px);
		}
	}

	@keyframes fieldErrorIn {
		from {
			opacity: 0;
			transform: translateY(-4px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.submit-button {
		background: linear-gradient(45deg, #16a34a, #22c55e);
		color: white;
		padding: 1.2rem 2.5rem;
		border: none;
		border-radius: 50px;
		font-size: 1.1rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		width: 100%;
		position: relative;
		overflow: hidden;
		margin-top: 1rem;
	}

	.submit-button span {
		position: relative;
		z-index: 2;
	}

	.submit-shine {
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
		transition: left 0.7s ease;
	}

	.submit-button:hover .submit-shine {
		left: 100%;
	}

	.submit-button:hover {
		transform: translateY(-3px) scale(1.02);
		box-shadow: 0 8px 25px rgba(34, 197, 94, 0.4);
	}

	.custom-alert {
		position: fixed;
		top: 24px;
		right: 24px;
		z-index: 10000;
		width: min(420px, calc(100vw - 32px));
		opacity: 0;
		transform: translateY(-12px) scale(0.98);
		pointer-events: none;
		transition:
			opacity 0.28s ease,
			transform 0.28s ease;
	}

	.custom-alert.show {
		opacity: 1;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}

	.custom-alert .alert-content {
		position: relative;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: start;
		gap: 0.9rem;
		padding: 1rem 1rem 1rem 0.95rem;
		border-radius: 18px;
		background: rgba(10, 25, 18, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow:
			0 18px 50px rgba(0, 0, 0, 0.35),
			0 0 0 1px rgba(255, 255, 255, 0.03) inset;
		backdrop-filter: blur(18px);
		overflow: hidden;
	}

	.custom-alert .alert-content::before {
		content: '';
		position: absolute;
		inset: 0 auto 0 0;
		width: 5px;
		border-radius: 18px 0 0 18px;
	}

	.custom-alert.error .alert-content::before {
		background: linear-gradient(180deg, #f87171, #ef4444);
	}

	.custom-alert.success .alert-content::before {
		background: linear-gradient(180deg, #4ade80, #22c55e);
	}

	.custom-alert .alert-content::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		height: 3px;
		width: 100%;
		transform-origin: left;
		animation: alertTimer 5s linear forwards;
	}

	.custom-alert.error .alert-content::after {
		background: linear-gradient(90deg, #f87171, #ef4444);
	}

	.custom-alert.success .alert-content::after {
		background: linear-gradient(90deg, #4ade80, #22c55e);
	}

	@keyframes alertTimer {
		from {
			transform: scaleX(1);
		}
		to {
			transform: scaleX(0);
		}
	}

	.custom-alert .alert-icon {
		width: 42px;
		height: 42px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		font-size: 1.1rem;
		flex-shrink: 0;
		margin-top: 1px;
	}

	.custom-alert.error .alert-icon {
		background: rgba(239, 68, 68, 0.14);
		color: #fca5a5;
	}

	.custom-alert.success .alert-icon {
		background: rgba(34, 197, 94, 0.14);
		color: #86efac;
	}

	.custom-alert .alert-text {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		min-width: 0;
	}

	.custom-alert .alert-title {
		color: #f8fafc;
		font-size: 0.96rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.custom-alert .alert-message {
		color: #d1d5db;
		font-size: 0.92rem;
		line-height: 1.45;
	}

	.custom-alert .alert-close {
		background: transparent;
		border: none;
		color: #94a3b8;
		font-size: 1.15rem;
		cursor: pointer;
		width: 34px;
		height: 34px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 10px;
		transition: all 0.2s ease;
		flex-shrink: 0;
	}

	.custom-alert .alert-close:hover {
		background: rgba(255, 255, 255, 0.08);
		color: white;
	}

	@media (max-width: 768px) {
		.contact {
			padding: 3rem 1rem;
		}

		.contact-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.contact-cta {
			flex-direction: column;
		}

		.cta-button {
			min-width: auto;
		}

		.contact h2 {
			font-size: 2rem;
		}

		.contact-title::after {
			width: 80px;
		}

		.message-title {
			font-size: 1.5rem;
		}

		.message-title::before {
			left: -30px;
		}

		.contact-message p {
			padding: 0.75rem;
		}

		.contact-message p:hover {
			transform: translateX(2px);
		}

		.form-title {
			font-size: 1.3rem;
		}

		.form-title::before {
			left: -30px;
		}

		.contact-form {
			padding: 2rem;
		}

		.contact-form:hover {
			transform: translateY(-1px);
		}

		.form-group input:focus,
		.form-group textarea:focus {
			transform: translateY(0);
		}

		.submit-button:hover {
			transform: translateY(-2px) scale(1.01);
		}

		.contact-bg-particles .particle-contact {
			width: 2px;
			height: 2px;
		}

		.custom-alert {
			top: 16px;
			right: 16px;
			left: 16px;
			width: auto;
		}

		.custom-alert .alert-content {
			padding: 0.9rem 0.9rem 0.95rem 0.85rem;
			border-radius: 16px;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const form = document.querySelector('.contact-form');
		if (!form) return;

		const inputs = Array.from(
			form.querySelectorAll('input[required], textarea[required]')
		);

		let hasTriedSubmit = false;

		inputs.forEach((input) => {
			input.addEventListener('input', () => {
				if (!hasTriedSubmit) return;
				validateField(input);
			});
		});

		form.addEventListener('submit', (e) => {
			e.preventDefault();
			hasTriedSubmit = true;

			let firstInvalidField = null;

			inputs.forEach((input) => {
				const isValid = validateField(input);

				if (!isValid && !firstInvalidField) {
					firstInvalidField = input;
				}
			});

			if (firstInvalidField) {
				const label = getFieldLabel(firstInvalidField);

				showCustomAlert(
					`Completá el campo "${label}" para poder enviar el mensaje.`,
					'error'
				);

				firstInvalidField.focus();

				const formGroup = firstInvalidField.closest('.form-group');
				if (formGroup) {
					formGroup.classList.add('shake');

					setTimeout(() => {
						formGroup.classList.remove('shake');
					}, 350);
				}

				return;
			}

			showCustomAlert('¡Mensaje enviado! Gracias por contactarte.', 'success');
			form.reset();

			inputs.forEach((input) => clearFieldError(input));
			hasTriedSubmit = false;
		});

		function getFieldLabel(input) {
			const formGroup = input.closest('.form-group');
			const label = formGroup ? formGroup.querySelector('label') : null;
			return label && label.textContent ? label.textContent.trim() : 'este campo';
		}

		function getErrorElement(formGroup) {
			let errorEl = formGroup.querySelector('.field-error');

			if (!errorEl) {
				errorEl = document.createElement('div');
				errorEl.className = 'field-error';
				errorEl.setAttribute('aria-live', 'polite');
				formGroup.appendChild(errorEl);
			}

			return errorEl;
		}

		function validateField(input) {
			const value = input.value.trim();
			const formGroup = input.closest('.form-group');
			if (!formGroup) return true;

			const label = getFieldLabel(input);

			if (!value) {
				formGroup.classList.add('has-error');
				input.setAttribute('aria-invalid', 'true');

				const errorEl = getErrorElement(formGroup);
				errorEl.textContent = `El campo "${label}" es obligatorio.`;

				return false;
			}

			if (input.type === 'email' && !isValidEmail(value)) {
				formGroup.classList.add('has-error');
				input.setAttribute('aria-invalid', 'true');

				const errorEl = getErrorElement(formGroup);
				errorEl.textContent = 'Ingresá un email válido.';

				return false;
			}

			clearFieldError(input);
			return true;
		}

		function clearFieldError(input) {
			const formGroup = input.closest('.form-group');
			if (!formGroup) return;

			formGroup.classList.remove('has-error');
			input.removeAttribute('aria-invalid');

			const errorEl = formGroup.querySelector('.field-error');
			if (errorEl) {
				errorEl.remove();
			}
		}

		function isValidEmail(email) {
			return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
		}

		function showCustomAlert(message, type = 'error') {
			const existingAlert = document.querySelector('.custom-alert');
			if (existingAlert) {
				existingAlert.remove();
			}

			const titles = {
				error: 'Falta completar información',
				success: 'Mensaje enviado'
			};

			const icons = {
				error: '⚠️',
				success: '✅'
			};

			const alert = document.createElement('div');
			alert.className = `custom-alert ${type}`;
			alert.setAttribute('role', 'status');
			alert.setAttribute('aria-live', 'polite');

			alert.innerHTML = `
				<div class="alert-content">
					<span class="alert-icon">${icons[type]}</span>
					<div class="alert-text">
						<span class="alert-title">${titles[type]}</span>
						<span class="alert-message">${message}</span>
					</div>
					<button class="alert-close" aria-label="Cerrar alerta">&times;</button>
				</div>
			`;

			document.body.appendChild(alert);

			requestAnimationFrame(() => {
				alert.classList.add('show');
			});

			const autoClose = setTimeout(() => {
				closeAlert(alert);
			}, 5000);

			const closeButton = alert.querySelector('.alert-close');
			if (closeButton) {
				closeButton.addEventListener('click', () => {
					clearTimeout(autoClose);
					closeAlert(alert);
				});
			}
		}

		function closeAlert(alert) {
			alert.classList.remove('show');
			setTimeout(() => alert.remove(), 280);
		}
	});
</script>
<!-- Contact.astro -->