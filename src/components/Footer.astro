---
// Footer component
---

<footer class="footer">
	<div class="container">
		<p>&copy; 2025 Agustín Farías. Desarrollador Full Stack.</p>
		<div class="social-links">
			<a href="[TU_GITHUB_URL]" target="_blank">GitHub</a>
			<a href="[TU_LINKEDIN_URL]" target="_blank">LinkedIn</a>
			<a href="mailto:[TU_EMAIL]">Email</a>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: linear-gradient(135deg, #0a1f0a 0%, #0f5132 100%);
		color: #d1fae5;
		padding: 2rem 0;
		text-align: center;
		border-top: 1px solid rgba(74, 222, 128, 0.2);
	}
	.footer .container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.footer p {
		margin: 0;
		font-size: 0.95rem;
		color: #a7f3d0;
	}
	.social-links {
		display: flex;
		gap: 2rem;
	}
	.social-links a {
		color: #4ade80;
		text-decoration: none;
		transition: color 0.3s;
		font-weight: 500;
		font-size: 0.95rem;
	}
	.social-links a:hover {
		color: #22c55e;
	}
	@media (max-width: 768px) {
		.footer .container {
			flex-direction: column;
			gap: 1rem;
		}
		.social-links {
			gap: 1.5rem;
		}
	}
</style>
<!-- Footer.astro -->